[configuration]
entry_symbol = "dream_coastline_init"
compatibility_minimum = 4.6
reloadable = true

[libraries]
linux.debug.x86_64 = "res://target/debug/libdream_coastline.so"
linux.release.x86_64 = "res://target/release/libdream_coastline.so"
windows.debug.x86_64 = "res://target/debug/dream_coastline.dll"
windows.release.x86_64 = "res://target/release/dream_coastline.dll"
macos.debug = "res://target/debug/libdream_coastline.dylib"
macos.release = "res://target/release/libdream_coastline.dylib"
macos.debug.arm64 = "res://target/debug/libdream_coastline.dylib"
macos.release.arm64 = "res://target/release/libdream_coastline.dylib"
