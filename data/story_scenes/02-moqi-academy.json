        "cabinet": {
          "name": "封存柜",
          "time_seconds": 45,
          "flags": ["checked_dictionary_cabinet"],
          "text": "柜门上的封条写着“未授权者不得授字”。夏离沉默了很久。"
        }
      },
      "glyph_actions": {
        "door": {
          "time_seconds": 55,
          "requires": ["learned_door", "checked_dictionary_cabinet"],
          "flags": ["got_basic_dictionary"],
          "glyph_mastery": {"door": 1},
          "text": "你写下“门”，不是破坏柜子，而是找到封条规则里的通行漏洞。基础字典到手。"
        }
      }
