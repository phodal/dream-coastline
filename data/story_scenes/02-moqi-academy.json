  "locations": {
    "academy": {
      "name": "隐秘书院",
      "art": [
        "+--------------------------------------------------------------+",
        "|  旧讲堂[书]      闻素        夏离                             |",
        "|    名 门 火 止   @                                           |",
        "|  黑板上写着：文字不是魔法，是接口。                           |",
        "+--------------------------------------------------------------+"
      ],
      "description": "夏离把你带到隐秘书院。闻素愿意教你基础墨文，但先让你承认自己真的不会。",
      "exits": {
        "village": "边境村落",
        "archive": "地下藏书室"
      },
      "items": {
        "wensu": {
          "name": "闻素",
          "time_seconds": 60,
          "flags": ["met_wensu"],
          "text": "闻素说：在墨颀，不会写字的人，不是愚笨。是不被允许存在得太完整。"
        },
        "baseline": {
          "name": "闻素的基线测试",
          "time_seconds": 90,
          "requires": ["met_wensu"],
          "flags": ["passed_wensu_baseline"],
          "text": "闻素没有立刻教新字，而是让你把听不懂、看不懂、误读的地方逐项写下。她说：先承认不知道，才有资格学习。"
        },
        "name": {
          "name": "名",
          "time_seconds": 45,
          "flags": ["learned_name"],
          "glyph_mastery": {"name": 1},
          "text": "你复习“名”。它不是标签，而是让一个对象被世界承认。"
        },
        "door": {
          "name": "门",
          "time_seconds": 50,
          "flags": ["learned_door"],
          "glyph_mastery": {"door": 1},
          "text": "“门”不是木板，而是通行规则。理解它后，地图上多出许多原本看不见的入口。"
        },
        "fire": {
          "name": "火",
          "time_seconds": 50,
          "flags": ["learned_fire"],
          "glyph_mastery": {"fire": 1},
          "text": "“火”是能源，也是警告。闻素让你先学会启动，再学会停止。"
        },
        "stop": {
          "name": "止",
          "time_seconds": 50,
          "flags": ["learned_stop"],
          "glyph_mastery": {"stop": 1},
          "text": "“止”不是停下动作，而是稳定边界。它能让裂纹暂时不再扩大。"
        }
      }
    },
    "village": {
      "name": "边境村落",
      "art": [
        "+--------------------------------------------------------------+",
        "|  村井[裂]        孩子们排队取水                               |",
        "|  水符□□          墨力炉(火?)                                 |",
        "|                       @                                      |",
        "+--------------------------------------------------------------+"
      ],
      "description": "村落水井的符文损坏。夏离想继续赶路，你却看见村民连基础维护都不会。",
      "location_intro": "村井上方漂着一只像黑色水影的鳐，腹部的井符忽明忽暗。它不是守护神，也不是怪物，只是被坏掉的水符困在半空。",
      "exits": {
        "academy": "隐秘书院",
        "archive": "地下藏书室"
      },
      "creature_encounters": {
        "creature_003_ink_well_ray": {
          "name": "墨井鳐",
          "first_meeting": "第一次修井失败后，墨井鳐从井口上方翻身，腹部符文短暂露出正确的水流方向。",
          "story_function": "它把墨颀生态和文字工程绑定起来：设施失稳，生态也会失稳。"
        }
      },
      "items": {
        "well": {
          "name": "裂开的水井",
          "time_seconds": 45,
          "flags": ["checked_broken_well"],
          "text": "井沿的裂纹像被删掉的笔画。水源还在，但名字和流向都不稳定。"
        },
        "first_failure": {
          "name": "第一次修井失败",
          "time_seconds": 80,
          "requires": ["checked_broken_well"],
          "flags": ["owned_first_repair_failure"],
          "text": "你照着字典抄了一遍旧符，井沿反而裂得更深。夏离想替你收场，闻素拦住他：失败也要记录，否则下一次还会有人照错。"
        },
        "villagers": {
          "name": "村民",
          "time_seconds": 55,
          "flags": ["saw_knowledge_lockout"],
          "text": "老人说他们只会照着旧符抄，没人教过为什么这样写。"
        },
        "ink_well_ray": {
          "name": "墨井鳐",
          "time_seconds": 55,
          "requires": ["owned_first_repair_failure"],
          "flags": ["read_ink_well_ray_feedback"],
          "text": "墨井鳐腹部的井符亮了一下，水流方向像被写错的笔画一样倒转。闻素说：别把它当神迹，这是系统反馈。"
        }
      },
      "encounters": {
        "contract_patrol": {
          "name": "巡契残影",
          "time_seconds": 40,
          "requires": ["learned_stop", "checked_broken_well"],
          "requires_mastery": {"stop": 1},
          "stat_costs": {"ink": 1, "focus": 1},
          "clear_flag": "cleared_contract_patrol",
          "flags": ["cleared_contract_patrol"],
          "metrics": {"trust": 1},
          "stats": {"stability": 1},
          "glyph_mastery": {"stop": 1},
          "text": "巡契残影从井边旧符里浮出。你用“止”稳住裂纹，把它压回封条残迹里。"
        }
      },
      "glyph_actions": {
        "stop": {
          "time_seconds": 45,
          "requires": ["learned_stop", "checked_broken_well"],
          "flags": ["stabilized_well_crack"],
          "stat_costs": {"ink": 1},
          "glyph_mastery": {"stop": 1},
          "text": "你写下“止”，井沿裂纹不再扩大。"
        },
        "fire": {
          "time_seconds": 45,
          "requires": ["learned_fire", "stabilized_well_crack"],
          "flags": ["started_ink_engine"],
          "stat_costs": {"ink": 1},
          "glyph_mastery": {"fire": 1},
          "text": "你用“火”启动旧墨力炉，水声重新从井底传来。"
        },
        "name": {
          "time_seconds": 45,
          "requires": ["learned_name", "started_ink_engine"],
          "flags": ["repaired_well"],
          "stats": {"ink": 1, "focus": 1},
          "glyph_mastery": {"name": 1},
          "text": "你用“名”确认水源。井口浮出清水，孩子们第一次喊出你的名字。"
        }
      }
    },
    "archive": {
      "name": "地下藏书室",
      "art": [
        "+--------------------------------------------------------------+",
